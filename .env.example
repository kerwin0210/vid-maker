# vid-maker 环境变量模板
# 复制此文件为 .env 并填入真实值
# ❌ 禁止将 .env 提交到 git

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vidmaker_dev
REDIS_URL=redis://localhost:6379

# ── AI API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxx
KLING_API_KEY=xxxxxxxxxxxxxxxxxxxx
KLING_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── 阿里云 ────────────────────────────────────────────────────────────────────
# OSS 文件存储
OSS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
OSS_BUCKET=vid-maker-dev
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://cdn.vid-maker.com

# 内容安全审核
ALIYUN_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
ALIYUN_CONTENT_SAFETY_REGION=cn-shanghai

# 短信验证码
ALIYUN_SMS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
ALIYUN_SMS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
ALIYUN_SMS_SIGN_NAME=vid-maker
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx

# ── 微信 ──────────────────────────────────────────────────────────────────────
# 微信登录
WECHAT_APP_ID=wx_xxxxxxxxxxxxxxxxxxxx
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# 微信支付
WECHAT_PAY_MCH_ID=xxxxxxxxxxxxxxxxxxxx
WECHAT_PAY_CERT_SERIAL=xxxxxxxxxxxxxxxxxxxx
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/wechat-pay-private-key.pem
WECHAT_PAY_API_V3_KEY=xxxxxxxxxxxxxxxxxxxx

# ── 支付宝 ────────────────────────────────────────────────────────────────────
ALIPAY_APP_ID=xxxxxxxxxxxxxxxxxxxx
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay-private-key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay-public-key.pem

# ── 认证 ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-32-char-random-secret-here
BETTER_AUTH_URL=http://localhost:3001

# ── 应用配置 ──────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
ADMIN_PORT=3002

# 成本告警阈值（单位：分，超过此值发告警）
COST_ALERT_THRESHOLD_CNY=5000

# Git 操作使用 SSH，已在 .git/config 配置 URL 重写规则
# 无需 GITHUB_TOKEN（github MCP 已移除）

# project-memory-rag 源码路径（未全局安装时使用）
# 本机填写 toolkit 的 src 目录路径，其他成员留空则使用 pip 安装版本
PMR_SRC_PATH=/path/to/project-memory-rag/src
