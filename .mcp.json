{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"],
      "env": {}
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${env:DATABASE_URL}"
      }
    },
    "redis": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-redis"],
      "env": {
        "REDIS_URL": "${env:REDIS_URL}",
        "MCP_MODE": "readonly"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "env": {}
    },
    "aliyun-oss": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-aws-s3"],
      "env": {
        "S3_ENDPOINT": "${env:OSS_ENDPOINT}",
        "S3_BUCKET": "${env:OSS_BUCKET}",
        "S3_ACCESS_KEY": "${env:OSS_ACCESS_KEY_ID}",
        "S3_SECRET_KEY": "${env:OSS_ACCESS_KEY_SECRET}",
        "MCP_MODE": "readonly"
      }
    },
    "cost-watcher": {
      "command": "python3",
      "args": ["-m", "cost_watcher.server"],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "MCP_MODE": "readonly"
      }
    },
    "project-memory": {
      "command": "python3",
      "args": ["-m", "project_memory_rag.server"],
      "env": {
        "PMR_DB_PATH": "${workspaceFolder}/.project-memory/vid-maker",
        "PMR_PROJECT": "vid-maker"
      }
    }
  }
}
